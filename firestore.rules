rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function myRole() {
      return isAuth() ? userDoc().data.role : '';
    }

    function isAdmin() {
      return myRole() == 'admin';
    }

    function isStaff() {
      return myRole() in ['admin', 'staff'];
    }

    function isViewer() {
      return myRole() in ['admin', 'staff', 'viewer'];
    }

    // الإعدادات — قراءة مفتوحة للتحميل الأولي
    match /settings/{doc} {
      allow read:  if true;
      allow write: if isAuth() && isAdmin();
    }

    // المستخدمون — قراءة مفتوحة للتحقق من أول مستخدم
    match /users/{uid} {
      allow read:   if true;
      allow create: if isAuth() && request.auth.uid == uid;
      allow update: if isAuth() && (request.auth.uid == uid || isAdmin());
      allow delete: if isAuth() && isAdmin();
    }

    // الأقسام الثلاثة — inventory
    match /departments/{dept}/inventory/{itemId} {
      allow read:   if isAuth() && isViewer();
      allow create: if isAuth() && isStaff();
      allow update: if isAuth() && isStaff();
      allow delete: if isAuth() && isAdmin();

      match /batches/{batchId} {
        allow read:   if isAuth() && isViewer();
        allow create: if isAuth() && isStaff();
        allow update: if isAuth() && isStaff();
        allow delete: if isAuth() && isAdmin();
      }
    }

    // الأقسام الثلاثة — movements
    match /departments/{dept}/movements/{movId} {
      allow read:           if isAuth() && isViewer();
      allow create:         if isAuth() && isStaff();
      allow update, delete: if isAuth() && isAdmin();
    }

    // Audit Log
    match /auditLog/{logId} {
      allow read:           if isAuth() && isAdmin();
      allow create:         if isAuth();
      allow update, delete: if false;
    }

    // الأرشيف
    match /archive/{year} {
      allow read:  if isAuth() && isAdmin();
      allow write: if isAuth() && isAdmin();

      match /{dept}/{doc} {
        allow read:  if isAuth() && isAdmin();
        allow write: if isAuth() && isAdmin();
      }
    }

    // تقديرات الاحتياج
    match /yearlyNeeds/{year} {
      allow read:  if isAuth() && isViewer();
      allow write: if isAuth() && isStaff();
    }

    // رفض كل شيء آخر
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

